# ============================================
#  קובץ תבנית למשתני סביבה (.env.example)
#  העתק קובץ זה ל-.env ומלא את הערכים האמיתיים.
#  אין למלא כאן ערכים אמיתיים — הקובץ הזה נשמר ב-Git.
# ============================================

# --- Claude API (ראובן + כל הצוות) ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- יובל — מעצב התמונות (יצירת תמונות) ---
IMAGE_API_KEY=your-image-api-key-here

# --- חן — החוקרת (חיפוש ומחקר) ---
SEARCH_API_KEY=your-search-api-key-here

# --- הגדרות כלליות ---
# סביבת הרצה: development | production
APP_ENV=development
